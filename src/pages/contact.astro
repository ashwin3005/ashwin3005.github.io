---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@lib/config';

const links = [
  {
    label: 'GitHub',
    href: SITE.author.github,
    desc: 'See what I\'m building',
    show: !!SITE.author.github,
  },
  {
    label: 'LinkedIn',
    href: SITE.author.linkedin,
    desc: 'Connect professionally',
    show: !!SITE.author.linkedin,
  },
  {
    label: 'Twitter / X',
    href: SITE.author.twitter ? `https://x.com/${SITE.author.twitter.replace('@', '')}` : '',
    desc: 'Shorter thoughts',
    show: !!SITE.author.twitter,
  },
  {
    label: 'Email',
    href: SITE.author.email ? `mailto:${SITE.author.email}` : '',
    desc: 'For anything else',
    show: !!SITE.author.email,
  },
].filter(l => l.show);
---

<BaseLayout
  title="Contact"
  description={`Ways to get in touch with ${SITE.author.name}.`}
>
  <div class="container contact-page">
    <header class="contact-header">
      <h1 class="contact-title">Contact</h1>
      <p class="contact-subtitle">
        The best way to reach me is via GitHub or email.
        I'll get back to you when I can.
      </p>
    </header>

    {links.length > 0 ? (
      <ul class="contact-list" role="list">
        {links.map(link => (
          <li>
            <a
              href={link.href}
              target={link.href.startsWith('mailto') ? undefined : '_blank'}
              rel={link.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
              class="contact-link"
            >
              <span class="contact-link-label">{link.label}</span>
              <span class="contact-link-desc">{link.desc}</span>
              <span class="contact-link-arrow" aria-hidden="true">&rarr;</span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="contact-fallback">
        Links coming soon — check back shortly.
      </p>
    )}
  </div>
</BaseLayout>

<style>
  .contact-page {
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
    max-width: 600px;
  }

  .contact-header {
    margin-bottom: var(--space-10);
  }

  .contact-title {
    font-size: var(--text-4xl);
    font-weight: 800;
    margin-bottom: var(--space-4);
  }

  .contact-subtitle {
    color: var(--color-text-muted);
    font-size: var(--text-base);
    line-height: 1.6;
  }

  .contact-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-4) var(--space-6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: border-color var(--transition), background var(--transition);
    background: var(--color-bg-subtle);
  }

  .contact-link:hover {
    border-color: var(--color-accent);
    background: var(--color-bg);
  }

  .contact-link-label {
    font-weight: 600;
    font-size: var(--text-base);
    color: var(--color-text);
    min-width: 120px;
  }

  .contact-link-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    flex: 1;
  }

  .contact-link-arrow {
    color: var(--color-text-muted);
    font-size: var(--text-lg);
    transition: color var(--transition), transform var(--transition);
  }

  .contact-link:hover .contact-link-arrow {
    color: var(--color-accent);
    transform: translateX(4px);
  }

  .contact-fallback {
    color: var(--color-text-muted);
  }
</style>
