---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import ProjectCard from '@components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import { sortPosts } from '@lib/utils';
import { SITE } from '@lib/config';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = sortPosts(allPosts);
const featuredPosts = posts.filter(p => p.data.featured).slice(0, 3);
const recentPosts = posts.slice(0, 3);
const displayPosts = featuredPosts.length > 0 ? featuredPosts : recentPosts;

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const homepageSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.author.name,
  url: SITE.url,
  description: SITE.description,
  sameAs: [SITE.author.github, SITE.author.linkedin].filter(Boolean),
};
---

<BaseLayout title="Home" description={SITE.description} schema={homepageSchema}>
  <div class="container">

    <section class="hero">
      <div class="hero-box">
        <div class="hero-name-row">
          <span class="prompt" aria-hidden="true">❯</span>
          <h1 class="hero-name">{SITE.author.name}<span class="cursor" aria-hidden="true">_</span></h1>
        </div>
        <p class="hero-role">AI Software Engineer @ Detect Technologies</p>
        <p class="hero-bio">
          Building computer vision and LLM systems.<br/>
          Exploring open-source and new ideas in AI research.
        </p>
        <nav class="hero-links" aria-label="Quick navigation">
          <a href="/blog">[ blog → ]</a>
          <a href="/about">[ about → ]</a>
          <a href="/contact">[ contact → ]</a>
        </nav>
      </div>
    </section>

    {displayPosts.length > 0 && (
      <section class="home-section">
        <div class="section-header">
          <h2 class="sh">{featuredPosts.length > 0 ? 'featured posts' : 'recent posts'}</h2>
          <a href="/blog" class="more-link">all posts →</a>
        </div>
        {displayPosts.map(post => <PostCard post={post} />)}
      </section>
    )}

    {featuredProjects.length > 0 && (
      <section class="home-section">
        <div class="section-header">
          <h2 class="sh">projects</h2>
          <a href="/projects" class="more-link">all projects →</a>
        </div>
        {featuredProjects.map(project => <ProjectCard project={project} />)}
      </section>
    )}

  </div>
</BaseLayout>

<style>
  .hero {
    padding: var(--space-16) 0 var(--space-12);
  }

  .hero-box {
    border: 1px solid var(--color-border);
    padding: var(--space-8);
    max-width: 480px;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .hero-name-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  .prompt {
    color: var(--color-accent);
    font-size: var(--text-3xl);
    line-height: 1;
    user-select: none;
  }

  .hero-name {
    font-size: var(--text-3xl);
    font-weight: 700;
    line-height: 1.15;
    color: var(--color-text);
  }

  .cursor {
    color: var(--color-accent);
    animation: blink 1.2s step-end infinite;
    font-weight: 400;
  }

  .hero-role {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .hero-bio {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .hero-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding-top: var(--space-2);
    border-top: 1px solid var(--color-border);
  }

  .hero-links a {
    font-size: var(--text-sm);
    color: var(--color-accent);
    text-decoration: none;
  }
  .hero-links a:hover { color: var(--color-accent-hover); }

  .home-section {
    padding-bottom: var(--space-12);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0;
  }

  .sh {
    margin-bottom: var(--space-4);
  }

  .more-link {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    text-decoration: none;
    align-self: flex-end;
    padding-bottom: 8px;
  }
  .more-link:hover { color: var(--color-accent); }
</style>
