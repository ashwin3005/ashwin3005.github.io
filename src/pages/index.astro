---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import ProjectCard from '@components/ProjectCard.astro';
import SocialLinks from '@components/SocialLinks.astro';
import { getCollection } from 'astro:content';
import { sortPosts } from '@lib/utils';
import { SITE } from '@lib/config';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = sortPosts(allPosts);
const featuredPosts = posts.filter(p => p.data.featured).slice(0, 3);
const recentPosts = posts.slice(0, 3);
const displayPosts = featuredPosts.length > 0 ? featuredPosts : recentPosts;

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.data.featured)
  .sort((a, b) => a.data.order - b.data.order);

const homepageSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.author.name,
  url: SITE.url,
  description: SITE.description,
  sameAs: [SITE.author.github, SITE.author.linkedin].filter(Boolean),
};
---

<BaseLayout title="Home" description={SITE.description} schema={homepageSchema}>
  <div class="container">

    <section class="hero">
      <h1 class="hero-name">{SITE.author.name}</h1>
      <p class="hero-role">AI Software Engineer @ Detect Technologies</p>
      <p class="hero-bio">
        Building computer vision and LLM systems, and exploring
        open-source and new ideas in AI research. This is where I write about
        what I'm building, learning, and thinking about.
      </p>
      <!-- <SocialLinks size="lg" class="hero-socials" /> -->
    </section>

    {displayPosts.length > 0 && (
      <section class="home-section">
        <div class="section-header">
          <h2 class="sh">{featuredPosts.length > 0 ? 'featured posts' : 'recent posts'}</h2>
          <a href="/blog" class="more-link">all posts →</a>
        </div>
        {displayPosts.map(post => <PostCard post={post} />)}
      </section>
    )}

    {featuredProjects.length > 0 && (
      <section class="home-section">
        <div class="section-header">
          <h2 class="sh">projects</h2>
          <a href="/projects" class="more-link">all projects →</a>
        </div>
        {featuredProjects.map(project => <ProjectCard project={project} />)}
      </section>
    )}

  </div>
</BaseLayout>

<style>
  .hero {
    padding: var(--space-16) 0 var(--space-12);
    max-width: 640px;
  }

  .hero-name {
    font-size: var(--text-4xl);
    font-weight: 800;
    line-height: 1.1;
    letter-spacing: -0.02em;
    color: var(--color-text);
    margin-bottom: var(--space-3);
  }

  .hero-role {
    font-size: var(--text-lg);
    font-weight: 500;
    color: var(--color-accent);
    margin-bottom: var(--space-6);
  }

  .hero-bio {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    line-height: 1.75;
    margin-bottom: var(--space-8);
  }

  .hero-socials {
    margin-top: var(--space-2);
  }

  .home-section {
    padding-bottom: var(--space-12);
  }

  .section-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 0;
  }

  .sh {
    margin-bottom: var(--space-4);
  }

  .more-link {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
    align-self: flex-end;
    padding-bottom: var(--space-2);
    white-space: nowrap;
  }
  .more-link:hover { color: var(--color-accent); }
</style>
