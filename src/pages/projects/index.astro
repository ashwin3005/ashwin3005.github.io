---
import BaseLayout from '@layouts/BaseLayout.astro';
import ProjectCard from '@components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Projects"
  description="Personal and open-source projects I've built or contributed to."
>
  <div class="container projects-page">

    <header class="projects-header">
      <h1 class="page-title">projects</h1>
      <span class="project-count">{sorted.length} projects</span>
    </header>

    <div class="project-list">
      {sorted.length > 0
        ? sorted.map(project => <ProjectCard project={project} />)
        : <p class="empty">more projects coming soon.</p>
      }
    </div>

  </div>
</BaseLayout>

<style>
  .projects-page {
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
  }

  .projects-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--color-border);
  }

  .page-title {
    font-size: var(--text-2xl);
    font-weight: 700;
  }

  .project-count {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .empty {
    color: var(--color-text-muted);
    padding: var(--space-8) 0;
  }
</style>
