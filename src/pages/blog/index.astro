---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import Search from '@components/Search.astro';
import { getCollection } from 'astro:content';
import { sortPosts, getAllTags } from '@lib/utils';
import '@styles/pagefind.css';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = sortPosts(allPosts);
const tags = getAllTags(allPosts);
---

<BaseLayout
  title="Blog"
  description="Writing on AI, computer vision, open-source, and things I'm building."
>
  <div class="container blog-page">

    <header class="blog-header">
      <h1 class="page-title">blog</h1>
      <span class="post-count">{posts.length} posts</span>
    </header>

    <div class="blog-controls">
      <Search />
      {tags.length > 0 && (
        <div class="tag-list" aria-label="Filter by tag">
          {tags.map(tag => (
            <a href={`/blog/tag/${tag}`} class="tag">{tag}</a>
          ))}
        </div>
      )}
    </div>

    <div class="post-list" aria-label="Blog posts">
      {posts.length > 0
        ? posts.map(post => <PostCard post={post} />)
        : <p class="empty">no posts yet.</p>
      }
    </div>

  </div>
</BaseLayout>

<style>
  .blog-page {
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
  }

  .blog-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    margin-bottom: var(--space-8);
  }

  .page-title {
    font-size: var(--text-2xl);
    font-weight: 700;
  }

  .post-count {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .blog-controls {
    margin-bottom: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .empty {
    color: var(--color-text-muted);
    padding: var(--space-8) 0;
  }
</style>
