---
import BaseLayout from '@layouts/BaseLayout.astro';
import PostCard from '@components/PostCard.astro';
import Search from '@components/Search.astro';
import { getCollection } from 'astro:content';
import { sortPosts, getAllTags } from '@lib/utils';
import '@styles/pagefind.css';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const posts = sortPosts(allPosts);
const tags = getAllTags(allPosts);

const currentTag = Astro.url.searchParams.get('tag') ?? null;
---

<BaseLayout
  title="Blog"
  description="Writing on dev/tech topics — systems programming, web development, open source, and more."
>
  <div class="container blog-page">
    <header class="blog-header">
      <h1 class="blog-title">Blog</h1>
      <p class="blog-subtitle">{posts.length} posts</p>
    </header>

    <div class="blog-layout">
      <!-- Sidebar: search + tags -->
      <aside class="blog-sidebar">
        <div class="sidebar-section">
          <Search />
        </div>

        {tags.length > 0 && (
          <div class="sidebar-section">
            <h2 class="sidebar-heading">Tags</h2>
            <div class="tag-list">
              {tags.map(tag => (
                <a href={`/blog/tag/${tag}`} class="tag">{tag}</a>
              ))}
            </div>
          </div>
        )}
      </aside>

      <!-- Post list -->
      <main class="post-list" aria-label="Blog posts">
        {posts.map(post => (
          <PostCard post={post} />
        ))}
      </main>
    </div>
  </div>
</BaseLayout>

<style>
  .blog-page {
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
  }

  .blog-header {
    margin-bottom: var(--space-10);
  }

  .blog-title {
    font-size: var(--text-4xl);
    font-weight: 800;
    margin-bottom: var(--space-2);
  }

  .blog-subtitle {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-family: var(--font-mono);
  }

  .blog-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: var(--space-12);
    align-items: start;
  }

  .blog-sidebar {
    position: sticky;
    top: 80px;
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .sidebar-heading {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-3);
  }

  .tag-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    align-items: flex-start;
  }

  .post-list {
    display: flex;
    flex-direction: column;
  }

  @media (max-width: 768px) {
    .blog-layout {
      grid-template-columns: 1fr;
    }

    .blog-sidebar {
      position: static;
    }

    .tag-list {
      flex-direction: row;
      flex-wrap: wrap;
    }
  }
</style>
