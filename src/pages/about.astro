---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@lib/config';

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.author.name,
  url: SITE.url,
  description: SITE.description,
  sameAs: [SITE.author.github, SITE.author.linkedin].filter(Boolean),
};

const skills = [
  'Python', 'C/C++', 'JavaScript', 'SQL', 'CUDA C',
  'PyTorch', 'LangChain', 'OpenCV', 'MMDetection', 'NumPy', 'Pandas',
  'PostgreSQL', 'MongoDB', 'ChromaDB', 'SQLite',
  'Linux', 'Docker', 'Git', 'MLflow',
];
---

<BaseLayout
  title="About"
  description={`About ${SITE.author.name} — background, skills, and what I'm working on.`}
  schema={aboutSchema}
>
  <div class="container about-page">
    <header class="about-header">
      <h1 class="about-title">About</h1>
    </header>

    <div class="about-content">
      <section class="about-section" aria-labelledby="bio-heading">
        <h2 id="bio-heading" class="section-heading">Who I am</h2>
        <div class="bio">
          <p>
            I'm {SITE.author.name}, an engineer building AI systems mostly on 
            computer vision and Agents.
            I work on applied AI problems and care about building systems that are
            efficient, reliable, and actually useful.
          </p>
          <p>
            This blog is where I document things I'm building, learning, and
            thinking about.
          </p>
        </div>
      </section>

      <section class="about-section" aria-labelledby="skills-heading">
        <h2 id="skills-heading" class="section-heading">Skills & tools</h2>
        <div class="skills-grid">
          {skills.map(skill => (
            <span class="skill-tag">{skill}</span>
          ))}
        </div>
      </section>

      <section class="about-section" aria-labelledby="contact-cta-heading">
        <h2 id="contact-cta-heading" class="section-heading">Get in touch</h2>
        <p class="contact-blurb">
          Interested in working together, or just want to say hello?
          Head over to the <a href="/contact">contact page</a>.
        </p>
      </section>
    </div>
  </div>
</BaseLayout>

<style>
  .about-page {
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
    max-width: 800px;
  }

  .about-header {
    margin-bottom: var(--space-10);
  }

  .about-title {
    font-size: var(--text-4xl);
    font-weight: 800;
  }

  .about-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .section-heading {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--color-border);
  }

  .bio {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .bio p {
    color: var(--color-text);
    line-height: 1.75;
    font-size: var(--text-base);
  }

  .skills-grid {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .skill-tag {
    padding: var(--space-2) var(--space-3);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    font-family: var(--font-mono);
    color: var(--color-text-muted);
  }

  .contact-blurb {
    color: var(--color-text-muted);
    font-size: var(--text-base);
    line-height: 1.6;
  }

  .contact-blurb a {
    color: var(--color-accent);
  }
</style>
