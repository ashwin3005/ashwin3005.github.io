---
import BaseLayout from '@layouts/BaseLayout.astro';
import { SITE } from '@lib/config';

const aboutSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: SITE.author.name,
  url: SITE.url,
  description: SITE.description,
  sameAs: [SITE.author.github, SITE.author.linkedin].filter(Boolean),
};

const skills = [
  'Python', 'C/C++', 'JavaScript', 'SQL', 'CUDA',
  'PyTorch', 'LangChain', 'OpenCV', 'MMDetection', 'NumPy', 'Pandas',
  'PostgreSQL', 'MongoDB', 'ChromaDB', 'SQLite',
  'Linux', 'Docker', 'Git', 'MLflow',
];
---

<BaseLayout
  title="About"
  description={`About ${SITE.author.name} — background, skills, and what I'm working on.`}
  schema={aboutSchema}
>
  <div class="container about-page">

    <header class="page-header">
      <div class="title-row">
        <span class="prompt" aria-hidden="true">❯</span>
        <h1 class="page-title">about</h1>
      </div>
    </header>

    <div class="about-body">

      <section class="section">
        <h2 class="section-label">who i am</h2>
        <div class="bio">
          <p>
            I'm {SITE.author.name}, an engineer building AI systems mostly on
            computer vision and Agents.
            I work on applied AI problems and care about building systems that are
            efficient, reliable, and actually useful.
          </p>
          <p>
            This blog is where I document things I'm building, learning, and
            thinking about.
          </p>
        </div>
      </section>

      <section class="section">
        <h2 class="section-label">skills & tools</h2>
        <ul class="skills-list">
          {skills.map(s => <li>{s}</li>)}
        </ul>
      </section>

      <section class="section">
        <h2 class="section-label">get in touch</h2>
        <p class="muted">
          Head over to the <a href="/contact">contact page</a> or reach out directly.
        </p>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .about-page {
    width: 100%;
    max-width: 640px;
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
  }

  .page-header { margin-bottom: var(--space-12); }

  .title-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
  }

  .prompt {
    color: var(--color-accent);
    font-size: var(--text-2xl);
    line-height: 1;
    user-select: none;
  }

  .page-title {
    font-size: var(--text-2xl);
    font-weight: 700;
  }

  .about-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-12);
  }

  .section-label {
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--color-text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: var(--space-2);
    margin-bottom: var(--space-6);
  }

  .bio {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .bio p {
    line-height: 1.75;
    color: var(--color-text);
  }

  .skills-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-2) var(--space-4);
  }

  .skills-list li {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding: var(--space-1) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .muted {
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  @media (max-width: 480px) {
    .skills-list {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
