---
import type { CollectionEntry } from 'astro:content';
import { formatDateISO } from '@lib/utils';

interface Props {
  paper: CollectionEntry<'papers'>;
}

const { paper } = Astro.props;
const { title, authors, year, venue, tags, pubDate, tldr } = paper.data;
const isoDate = formatDateISO(pubDate);

const meta = [authors, venue && year ? `${venue} ${year}` : (venue ?? (year ? String(year) : ''))].filter(Boolean).join(' · ');
---

<article class="paper-row">
  <time datetime={pubDate.toISOString()} class="paper-date">{isoDate}</time>
  <div class="paper-main">
    <a href={`/papers/${paper.slug}`} class="paper-title">{title}</a>
    {meta && <p class="paper-meta">{meta}</p>}
    {tldr && <p class="paper-tldr">{tldr}</p>}
  </div>
  {tags.length > 0 && (
    <div class="paper-tags">
      {tags.map(tag => (
        <a href={`/papers/tag/${tag}`} class="tag">{tag}</a>
      ))}
    </div>
  )}
</article>

<style>
  .paper-row {
    display: grid;
    grid-template-columns: 10ch 1fr auto;
    align-items: start;
    gap: 0 var(--space-6);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .paper-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    padding-top: 3px;
    white-space: nowrap;
  }

  .paper-main {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .paper-title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    line-height: 1.4;
  }
  .paper-title:hover { color: var(--color-accent); text-decoration: none; }

  .paper-meta {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
  }

  .paper-tldr {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
    font-style: italic;
  }

  .paper-tags {
    display: flex;
    flex-direction: column;
    gap: 3px;
    align-items: flex-end;
    padding-top: 3px;
  }

  @media (max-width: 580px) {
    .paper-row {
      grid-template-columns: 1fr;
    }
    .paper-date { order: 2; padding-top: var(--space-1); }
    .paper-main { order: 1; }
    .paper-tags { display: none; }
  }
</style>
