---
import type { CollectionEntry } from 'astro:content';
import { readingTime, formatDateShort } from '@lib/utils';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const time = readingTime(post.body);
---

<article class="post-card">
  <div class="post-card-meta">
    <time datetime={pubDate.toISOString()} class="post-card-date">
      {formatDateShort(pubDate)}
    </time>
    <span class="meta-sep" aria-hidden="true">·</span>
    <span class="post-card-time">{time}</span>
  </div>

  <h2 class="post-card-title">
    <a href={`/blog/${post.slug}`}>{title}</a>
  </h2>

  <p class="post-card-desc">{description}</p>

  {tags.length > 0 && (
    <div class="post-card-tags">
      {tags.map(tag => (
        <a href={`/blog/tag/${tag}`} class="tag">{tag}</a>
      ))}
    </div>
  )}
</article>

<style>
  .post-card {
    padding: var(--space-6) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-card:last-child {
    border-bottom: none;
  }

  .post-card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    font-family: var(--font-mono);
    margin-bottom: var(--space-2);
  }

  .meta-sep { color: var(--color-border); }

  .post-card-title {
    font-size: var(--text-xl);
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: var(--space-2);
  }

  .post-card-title a {
    color: var(--color-text);
    text-decoration: none;
    transition: color var(--transition);
  }

  .post-card-title a:hover {
    color: var(--color-accent);
  }

  .post-card-desc {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    line-height: 1.6;
    margin-bottom: var(--space-3);
  }

  .post-card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }
</style>
