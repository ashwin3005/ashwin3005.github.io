---
import type { CollectionEntry } from 'astro:content';
import { formatDateISO } from '@lib/utils';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const isoDate = formatDateISO(pubDate);
---

<article class="post-row">
  <time datetime={pubDate.toISOString()} class="post-date">{isoDate}</time>
  <div class="post-main">
    <a href={`/blog/${post.slug}`} class="post-title">{title}</a>
    <p class="post-desc">{description}</p>
  </div>
  {tags.length > 0 && (
    <div class="post-tags" aria-label="Tags">
      {tags.map(tag => (
        <a href={`/blog/tag/${tag}`} class="tag">{tag}</a>
      ))}
    </div>
  )}
</article>

<style>
  .post-row {
    display: grid;
    grid-template-columns: 10ch 1fr auto;
    align-items: start;
    gap: 0 var(--space-6);
    padding: var(--space-4) 0;
    border-bottom: 1px solid var(--color-border);
  }

  .post-date {
    font-size: var(--text-xs);
    color: var(--color-text-muted);
    padding-top: 3px;
    white-space: nowrap;
  }

  .post-main {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .post-title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
    line-height: 1.4;
  }
  .post-title:hover { color: var(--color-accent); text-decoration: none; }

  .post-desc {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  .post-tags {
    display: flex;
    flex-direction: column;
    gap: 3px;
    align-items: flex-end;
    padding-top: 3px;
  }

  @media (max-width: 580px) {
    .post-row {
      grid-template-columns: 1fr;
    }
    .post-date { order: 2; padding-top: var(--space-1); }
    .post-main { order: 1; }
    .post-tags { display: none; }
  }
</style>
