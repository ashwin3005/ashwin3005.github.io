---
import { SITE } from '@lib/config';

interface Props {
  /** visual size variant */
  size?: 'md' | 'lg';
  class?: string;
}

const { size = 'md', class: className } = Astro.props;

const twitter = SITE.author.twitter?.replace('@', '');

const links = [
  {
    label: 'GitHub',
    href: SITE.author.github,
    show: !!SITE.author.github,
    icon: 'github',
  },
  {
    label: 'X',
    href: twitter ? `https://x.com/${twitter}` : '',
    show: !!twitter,
    icon: 'x',
  },
  {
    label: 'LinkedIn',
    href: SITE.author.linkedin,
    show: !!SITE.author.linkedin,
    icon: 'linkedin',
  },
  {
    label: 'Email',
    href: SITE.author.email ? `mailto:${SITE.author.email}` : '',
    show: !!SITE.author.email,
    icon: 'email',
  },
].filter(l => l.show);
---

<ul class:list={['socials', `socials-${size}`, className]} aria-label="Social links">
  {links.map(l => (
    <li>
      <a
        href={l.href}
        class="social"
        aria-label={l.label}
        title={l.label}
        target={l.href.startsWith('mailto') ? undefined : '_blank'}
        rel={l.href.startsWith('mailto') ? undefined : 'noopener noreferrer'}
      >
        {l.icon === 'github' && (
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.305-5.467-1.334-5.467-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
        )}
        {l.icon === 'x' && (
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        )}
        {l.icon === 'linkedin' && (
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0z"/></svg>
        )}
        {l.icon === 'email' && (
          <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path fill="currentColor" d="M1.5 4h21A1.5 1.5 0 0 1 24 5.5v13a1.5 1.5 0 0 1-1.5 1.5h-21A1.5 1.5 0 0 1 0 18.5v-13A1.5 1.5 0 0 1 1.5 4Zm.9 2 9.6 6.75L21.6 6H2.4ZM22 7.3l-9.43 6.63a1 1 0 0 1-1.14 0L2 7.3V18h20V7.3Z"/></svg>
        )}
      </a>
    </li>
  ))}
</ul>

<style>
  .socials {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding: 0;
    margin: 0;
  }

  .social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    color: var(--color-text-muted);
    background: var(--color-bg);
    text-decoration: none;
    transition: color var(--transition), border-color var(--transition),
      background var(--transition), transform var(--transition);
  }

  .social:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    transform: translateY(-2px);
    text-decoration: none;
  }

  .social svg { display: block; }

  /* size variants */
  .socials-md .social { width: 42px; height: 42px; }
  .socials-md svg { width: 20px; height: 20px; }

  .socials-lg .social { width: 50px; height: 50px; }
  .socials-lg svg { width: 24px; height: 24px; }
</style>
