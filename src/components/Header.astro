---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/blog',     label: 'blog'     },
  { href: '/papers',   label: 'papers'   },
  { href: '/projects', label: 'projects' },
  { href: '/about',    label: 'about'    },
  { href: '/contact',  label: 'contact'  },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header" data-pagefind-ignore>
  <div class="container header-inner">
    <nav class="nav" aria-label="Main navigation">
      <a href="/" class="home-link" aria-label="Home">~/</a>
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', { active: currentPath.startsWith(link.href) }]}
        >
          {link.label}
        </a>
      ))}
      <!-- mobile-only toggle, hidden on desktop via CSS -->
      <button class="menu-btn" id="menu-btn" aria-label="Toggle navigation" aria-expanded="false">
        [menu]
      </button>
    </nav>
    <ThemeToggle />
  </div>

  <!-- mobile drawer, hidden by default -->
  <nav class="mobile-drawer" id="mobile-drawer" aria-label="Mobile navigation" aria-hidden="true">
    {navLinks.map(link => (
      <a
        href={link.href}
        class:list={['drawer-link', { active: currentPath.startsWith(link.href) }]}
      >
        {link.label}
      </a>
    ))}
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
    transition: background-color var(--transition);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 44px;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  .home-link {
    font-weight: 700;
    color: var(--color-accent);
    text-decoration: none;
    letter-spacing: -0.01em;
    flex-shrink: 0;
  }
  .home-link:hover { color: var(--color-accent-hover); }

  .nav-link {
    color: var(--color-text-muted);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: color var(--transition);
  }
  .nav-link:hover { color: var(--color-accent); }
  .nav-link.active { color: var(--color-accent); }

  /* mobile toggle — hidden on desktop */
  .menu-btn {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    padding: 0;
  }
  .menu-btn:hover { color: var(--color-accent); }

  /* mobile drawer — hidden by default */
  .mobile-drawer {
    display: none;
    flex-direction: column;
    gap: var(--space-1);
    padding: var(--space-3) var(--space-8) var(--space-4);
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
  }
  .mobile-drawer.open {
    display: flex;
  }

  .drawer-link {
    font-size: var(--text-base);
    color: var(--color-text-muted);
    text-decoration: none;
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-border);
  }
  .drawer-link:last-child { border-bottom: none; }
  .drawer-link:hover,
  .drawer-link.active { color: var(--color-accent); }

  /* on mobile: hide desktop links, show toggle button */
  @media (max-width: 560px) {
    .nav-link { display: none; }
    .menu-btn { display: inline; }
  }

  @media (min-width: 561px) {
    .mobile-drawer { display: none !important; }
  }
</style>

<script>
  const btn = document.getElementById('menu-btn');
  const drawer = document.getElementById('mobile-drawer');

  btn?.addEventListener('click', () => {
    const isOpen = drawer?.classList.contains('open');
    drawer?.classList.toggle('open', !isOpen);
    btn.textContent = isOpen ? '[menu]' : '[close]';
    btn.setAttribute('aria-expanded', String(!isOpen));
    drawer?.setAttribute('aria-hidden', String(isOpen));
  });
</script>
