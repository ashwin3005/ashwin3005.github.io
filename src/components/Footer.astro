---
import { SITE } from '@lib/config';

const year = new Date().getFullYear();

const socials = [
  { href: SITE.author.github, label: 'GitHub', show: !!SITE.author.github },
  { href: SITE.author.linkedin, label: 'LinkedIn', show: !!SITE.author.linkedin },
  { href: SITE.author.twitter ? `https://x.com/${SITE.author.twitter.replace('@', '')}` : '', label: 'Twitter / X', show: !!SITE.author.twitter },
].filter(s => s.show);
---

<footer class="site-footer" data-pagefind-ignore>
  <div class="container footer-inner">
    <p class="footer-copy">
      &copy; {year} {SITE.author.name}
    </p>
    {socials.length > 0 && (
      <nav aria-label="Social links" class="footer-socials">
        {socials.map(s => (
          <a href={s.href} target="_blank" rel="noopener noreferrer" class="footer-link">
            {s.label}
          </a>
        ))}
      </nav>
    )}
    <p class="footer-built">
      Built with <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a>
    </p>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    padding: var(--space-8) 0;
    margin-top: var(--space-16);
  }

  .footer-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer-copy,
  .footer-built {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .footer-built a {
    color: var(--color-text-muted);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer-built a:hover {
    color: var(--color-accent);
  }

  .footer-socials {
    display: flex;
    gap: var(--space-4);
  }

  .footer-link {
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    text-decoration: none;
    transition: color var(--transition);
  }

  .footer-link:hover {
    color: var(--color-accent);
  }
</style>
