---
import BaseLayout from './BaseLayout.astro';
import SeriesNav from '@components/SeriesNav.astro';
import { SITE } from '@lib/config';
import { formatDate } from '@lib/utils';
import type { CollectionEntry } from 'astro:content';
import '@styles/prose.css';

interface Props {
  post: CollectionEntry<'blog'>;
  readingTime: string;
  seriesPosts?: CollectionEntry<'blog'>[];
}

const { post, readingTime, seriesPosts = [] } = Astro.props;
const { title, description, pubDate, updatedDate, tags, series, ogImage } = post.data;

const canonical = new URL(`/blog/${post.slug}`, SITE.url).href;
const ogImg = ogImage ?? SITE.defaultOgImage;

const postSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: title,
  description,
  datePublished: pubDate.toISOString(),
  dateModified: (updatedDate ?? pubDate).toISOString(),
  author: {
    '@type': 'Person',
    name: SITE.author.name,
    url: SITE.url,
  },
  publisher: {
    '@type': 'Person',
    name: SITE.author.name,
  },
  url: canonical,
  image: new URL(ogImg, SITE.url).href,
  keywords: tags.join(', '),
  inLanguage: 'en-US',
};
---

<BaseLayout
  title={title}
  description={description}
  ogImage={ogImg}
  canonicalUrl={canonical}
  schema={postSchema}
  ogType="article"
>
  <Fragment slot="head">
    <meta property="article:published_time" content={pubDate.toISOString()} />
    {updatedDate && <meta property="article:modified_time" content={updatedDate.toISOString()} />}
    <meta property="article:author" content={SITE.author.name} />
    {tags.map(tag => <meta property="article:tag" content={tag} />)}
  </Fragment>

  <div class="container post-container">
    <header class="post-header">
      <div class="post-meta">
        <time datetime={pubDate.toISOString()} class="post-date">
          {formatDate(pubDate)}
        </time>
        <span class="meta-sep" aria-hidden="true">·</span>
        <span class="post-reading-time">{readingTime}</span>
        {updatedDate && (
          <>
            <span class="meta-sep" aria-hidden="true">·</span>
            <span class="post-updated">Updated {formatDate(updatedDate)}</span>
          </>
        )}
      </div>

      <h1 class="post-title">{title}</h1>
      <p class="post-description">{description}</p>

      {tags.length > 0 && (
        <div class="post-tags" aria-label="Tags">
          {tags.map(tag => (
            <a href={`/blog/tag/${tag}`} class="tag">{tag}</a>
          ))}
        </div>
      )}
    </header>

    {series && seriesPosts.length > 0 && (
      <SeriesNav seriesPosts={seriesPosts} currentSlug={post.slug} seriesName={series} />
    )}

    <article class="prose" data-pagefind-body>
      <h1 data-pagefind-meta="title" style="display:none">{title}</h1>
      <slot />
    </article>

    <footer class="post-footer">
      {tags.length > 0 && (
        <div class="post-footer-tags">
          <span class="footer-tags-label">Tags:</span>
          {tags.map(tag => (
            <a href={`/blog/tag/${tag}`} class="tag">{tag}</a>
          ))}
        </div>
      )}
      <a href="/blog" class="back-link">&larr; All posts</a>
    </footer>
  </div>
</BaseLayout>

<style>
  .post-container {
    padding-top: var(--space-12);
    padding-bottom: var(--space-16);
  }

  .post-header {
    max-width: var(--max-width-prose);
    margin-bottom: var(--space-8);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
    font-family: var(--font-mono);
  }

  .meta-sep { color: var(--color-border); }

  .post-title {
    font-size: var(--text-3xl);
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-text);
    margin-bottom: var(--space-4);
  }

  .post-description {
    font-size: var(--text-lg);
    color: var(--color-text-muted);
    line-height: 1.6;
    margin-bottom: var(--space-6);
  }

  .post-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .post-footer {
    max-width: var(--max-width-prose);
    margin-top: var(--space-12);
    padding-top: var(--space-8);
    border-top: 1px solid var(--color-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
  }

  .post-footer-tags {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .footer-tags-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .back-link {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    text-decoration: none;
  }
  .back-link:hover { color: var(--color-text); }

  @media (max-width: 640px) {
    .post-title { font-size: var(--text-3xl); }
  }
</style>
